{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "serve -s dist -l 3000",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
